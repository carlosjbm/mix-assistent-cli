{
  "name": "openmix-cli",
  "version": "1.4.0",
  "description": "Asistente CLI para la automatización de procesos repetitivos del soporte a la SUITE ZUN",
  "main": "src/index.js",
  "bin": {
    "openmix": "src/index.js",
    "opx-validate": "src/utils/validateStructure.js",
    "opx-clone": "src/services/cloneFiles.js",
    "opx-act": "src/utils/actZun.js",
    "opx-fix": "src/services/fixFolderEspecific.js",
    "opx-installed": "src/utils/installedModules.js",
    "opx-versioninfo": "src/utils/versionInfo.js",
    "opx-help": "src/utils/help.js",
    "opx-version": "src/utils/version.js",
    "opx-back": "src/services/backupModule.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "jest",
    "validate": "node src/utils/validateStructure.js",
    "clone": "node src/services/cloneFiles.js",
    "act": "node src/utils/actZun.js",
    "fix": "node src/services/fixFolderEspecific.js",
    "installed": "node src/utils/installedModules.js",
    "help": "node src/utils/help.js",
    "version": "node src/utils/version.js"
  },
  "keywords": [
    "ZUN",
    "zun-cli",
    "asistente",
    "cli",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/carlosjbm/mix-assistent-cli/"
  },
  "author": "carlinhos",
  "license": "MIT",
  "dependencies": {
    "keypress": "^0.2.1",
    "win-version-info": "^6.0.1"
  }
